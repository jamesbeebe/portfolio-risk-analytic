# Copy this file to .env and fill in your values
# Never commit your actual .env file

# Database — local SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./portfolio_risk.db

# Database — Supabase PostgreSQL (uncomment and fill in for cloud)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS — add your deployed Streamlit URL here when deploying
EXTRA_CORS_ORIGINS=
